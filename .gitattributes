# Auto-detect text vs binary, normalize text to LF in the repo.
# Windows working copies still get CRLF on checkout (core.autocrlf=true).
* text=auto eol=lf

# Force LF for shell scripts (Gradle wrapper) — they break with CRLF.
*.sh        text eol=lf
gradlew     text eol=lf

# Force CRLF for Windows-only files.
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Mark binary files explicitly.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.jar       binary
*.apk       binary
*.aab       binary
*.keystore  binary
